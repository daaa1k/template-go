{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "5 days",
  "schedule": ["* 10-14 * * 6"],
  "timezone": "Asia/Tokyo",
  "assignees": ["{{ owner }}"],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Group Go module patch updates into one PR",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go patch dependencies",
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Group GitHub Actions patch updates into one PR",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "groupName": "github-actions patch",
      "commitMessagePrefix": "ci:"
    },
    {
      "description": "Group mise patch updates into one PR",
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["patch"],
      "groupName": "mise patch dependencies",
      "commitMessagePrefix": "chore:"
    },
    {
      "description": "Prefix non-patch Go module updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Prefix non-patch GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "ci:"
    },
    {
      "description": "Prefix non-patch mise updates",
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "chore:"
    },
    {
      "description": "Do not apply minimum release age to {{ owner }} GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["{{ owner }}/{/,}**"],
      "minimumReleaseAge": null
    },
    {
      "description": "Do not apply minimum release age to copier",
      "matchManagers": ["copier"],
      "minimumReleaseAge": null,
      "commitMessagePrefix": "chore:"
    }
  ]
}
